{
  "installCommand": "cd chatbotWeb/chatBotWeb && npm install --include=dev --no-audit --no-fund",
  "buildCommand": "cd chatbotWeb/chatBotWeb && npm run build",
  "outputDirectory": "chatbotWeb/chatBotWeb/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
